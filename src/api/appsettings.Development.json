{
  "ConnectionStrings": {
    "Default": "Host=localhost;Port=5432;Database=dmarc_analyzer;Username=postgres;Password=postgres"
  },
  "Worker": {
    "ScheduleIntervalSeconds": 15,
    "MaxMessagesPerSync": 50,
    "MaxRetryAttempts": 3,
    "RetryBaseDelaySeconds": 2,
    "StaleRunTimeoutMinutes": 20,
    "SyncRunTimeoutMinutes": 10
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  }
}
