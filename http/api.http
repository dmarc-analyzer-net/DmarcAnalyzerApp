@baseUrl = http://localhost:5076
@mailboxSourceId = 00000000-0000-0000-0000-000000000000

### Health/status
GET {{baseUrl}}/api/v1/system/status

### Apply migrations
POST {{baseUrl}}/api/v1/admin/database/migrate

### List clients
GET {{baseUrl}}/api/v1/clients

### Create client
POST {{baseUrl}}/api/v1/clients
Content-Type: application/json

{
  "name": "Acme Demo",
  "slug": "acme-demo",
  "retentionMonths": 27,
  "timezone": "UTC",
  "isActive": true
}

### Get client by id (replace id)
GET {{baseUrl}}/api/v1/clients/00000000-0000-0000-0000-000000000000

### Patch client (replace id)
PATCH {{baseUrl}}/api/v1/clients/00000000-0000-0000-0000-000000000000
Content-Type: application/json

{
  "timezone": "Europe/Copenhagen"
}

### List domains
GET {{baseUrl}}/api/v1/domains

### List domains by clientId (replace clientId)
GET {{baseUrl}}/api/v1/domains?clientId=00000000-0000-0000-0000-000000000000

### Create domain (replace clientId)
POST {{baseUrl}}/api/v1/domains
Content-Type: application/json

{
  "clientId": "00000000-0000-0000-0000-000000000000",
  "name": "example.com",
  "isActive": true
}

### Get domain by id (replace id)
GET {{baseUrl}}/api/v1/domains/00000000-0000-0000-0000-000000000000

### Patch domain (replace id)
PATCH {{baseUrl}}/api/v1/domains/00000000-0000-0000-0000-000000000000
Content-Type: application/json

{
  "isActive": false
}

### List mailbox sources
GET {{baseUrl}}/api/v1/mailbox-sources

### Create mailbox source (replace defaultClientId)
POST {{baseUrl}}/api/v1/mailbox-sources
Content-Type: application/json

{
  "name": "Acme DMARC Inbox",
  "protocol": "imap",
  "host": "imap.example.com",
  "port": 993,
  "useTls": true,
  "username": "dmarc@example.com",
  "password": "replace-me",
  "defaultClientId": "00000000-0000-0000-0000-000000000000",
  "isActive": true
}

### Patch mailbox source (replace id)
PATCH {{baseUrl}}/api/v1/mailbox-sources/00000000-0000-0000-0000-000000000000
Content-Type: application/json

{
  "isActive": false,
  "port": 995,
  "protocol": "pop3"
}

### Manual mailbox sync (IMAP only; read-only, does not delete emails)
POST {{baseUrl}}/api/v1/mailbox-sources/{{mailboxSourceId}}/sync

### List mailbox sync runs (optional mailboxSourceId, optional limit)
GET {{baseUrl}}/api/v1/mailbox-sync-runs?mailboxSourceId={{mailboxSourceId}}&limit=20

### Mailbox health summary (optional mailboxSourceId)
GET {{baseUrl}}/api/v1/mailbox-health?mailboxSourceId={{mailboxSourceId}}
